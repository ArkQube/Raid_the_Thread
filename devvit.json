{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "raid-the-thread",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create Raid the Thread Post",
        "description": "Create a new daily community boss raid",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Reset Daily Raid Data",
        "description": "Wipe today's boss damage and player data (for testing)",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/reset-raid"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "daily_raid": {
        "cron": "0 0 * * *",
        "endpoint": "/internal/scheduler/daily-raid"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "raid_the_thread"
  }
}
